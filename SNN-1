def main():
    imu_path = "sample_data/imu.txt"
    out_png  = "imu_snn_result.png"
    out_csv  = "imu_snn_trajectory.csv"

    print("="*65)
    print("  IMU SNN-SLAM  —  Spiking Neural Network Navigation  v1")
    print("="*65)

    if Path(imu_path).exists():
        data = np.loadtxt(imu_path, comments="#")
        print(f"[LOAD]  {data.shape[0]} samples from '{imu_path}'")
    else:
        print(f"[WARN]  '{imu_path}' not found — generating synthetic data")
        data = generate_synthetic_imu(duration=30.0, hz=200)
        print(f"[SYN]   {data.shape[0]} samples generated")

    res = run_snn_slam(
        data,
        n_static        = 200,
        zupt_thresh     = 0.04,
        zupt_win        = 15,
        n_steps         = 8,
        pretrain_epochs = 30,
        velocity_scale  = 0.08,
        attitude_scale  = 0.015,
        lc_sim_thresh   = 0.88,
        lc_min_gap      = 5.0,
        lc_radius       = 3.0,
    )

    # CSV export
    t_rel = res["ts"] - res["ts"][0]
    out = np.column_stack([
        t_rel, res["pos"], res["vel"],
        np.degrees(res["euler"]),
        res["gbias"], res["abias"],
        res["fire_rate"],
        res["zupt"].astype(int),
        res["lc"].astype(int),
        res["lc_sim"],
        np.linalg.norm(res["vel"],axis=1)
    ])
    hdr = ("time_s,x,y,z,vx,vy,vz,"
           "roll_deg,pitch_deg,yaw_deg,"
           "gbx,gby,gbz,abx,aby,abz,"
           "fire_rate,zupt,loop_closure,lc_similarity,speed_ms")
    np.savetxt(out_csv, out, delimiter=",", header=hdr, comments="")
    print(f"[CSV]   Saved → {out_csv}")

    plot_snn(res, save_path=out_png)
    print(f"\n[DONE]  All outputs written.")


if __name__ == "__main__":
    main()
