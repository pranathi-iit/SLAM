# 4.  SNN Motion Classifier  (STATIC / SLOW / FAST)
# ══════════════════════════════════════════════════════════════════════════════

class SNNMotionClassifier:
    """
    3-class winner-take-all (WTA) SNN classifier.
    Replaces the simple threshold ZUPT of previous pipelines.

    Input neurons: gyro magnitude + accel variance → 12 encoder neurons
    Output layer : 3 neurons with lateral inhibition
        Neuron 0 → STATIC   (velocity = 0)
        Neuron 1 → SLOW     (low-speed motion)
        Neuron 2 → FAST     (high-speed / aggressive motion)

    Lateral inhibition: when one output neuron fires, it suppresses the others.
    This ensures only ONE class wins per timestep (WTA).
    """
    def __init__(self):
        self.feature_enc = RateEncoder(n_channels=2, n_pop=6,
                                       val_min=0.0, val_max=20.0,
                                       max_rate=150.0)
        # Output layer: 3 class neurons
        self.output = LIFNeuron(3, tau=0.015, v_thresh=0.7,
                                v_reset=-0.1, t_ref=0.003)

        # Weights: feature (12) → output (3)
        self.W = np.array([
            # STATIC: responds strongly to near-zero gyro + low accel var
            [0.4, 0.3, 0.15, 0.05, 0.01, 0.0,   # gyro mag features
             0.4, 0.3, 0.15, 0.05, 0.01, 0.0],  # accel var features
            # SLOW: mid-range response
            [0.0, 0.1, 0.3, 0.3, 0.2,  0.05,
             0.0, 0.1, 0.3, 0.3, 0.2,  0.05],
            # FAST: high gyro/accel
            [0.0, 0.0, 0.05, 0.15, 0.35, 0.45,
             0.0, 0.0, 0.05, 0.15, 0.35, 0.45],
        ])

        # Lateral inhibition weights (off-diagonal)
        self.W_inh = 0.6 * (np.ones((3,3)) - np.eye(3))

        self._gyro_buf  = []
        self._accel_buf = []
        self._window    = 12
        self._state_hist = []       # for plotting
        self._LABELS = ["STATIC","SLOW","FAST"]

    def step(self, gyro_corr: np.ndarray,
             accel_raw: np.ndarray, dt: float) -> int:
        gm = float(np.linalg.norm(gyro_corr))

        self._gyro_buf.append(gyro_corr.copy())
        self._accel_buf.append(accel_raw.copy())
        if len(self._gyro_buf) > self._window:
            self._gyro_buf.pop(0); self._accel_buf.pop(0)

        accel_var = float(np.var(np.array(self._accel_buf)))
        features  = np.array([gm, accel_var])

        spikes_in = self.feature_enc.encode(features, dt)   # (12,)
        I_exc = self.W @ spikes_in                           # (3,) excitation

        # Lateral inhibition from last step's output membrane potential
        I_inh = self.W_inh @ (self.output.V - self.output.rest)
        I_total = I_exc - np.maximum(0, I_inh)

        out_spikes = self.output.step(I_total, dt)

        # Winner = neuron with highest membrane potential
        winner = int(np.argmax(self.output.V))
        self._state_hist.append(winner)
        return winner, out_spikes


