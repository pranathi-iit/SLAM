# 8.  Visualisation — 16-panel SNN dashboard
# ══════════════════════════════════════════════════════════════════════════════

def plot_snn(res, save_path=None):
    ts    = res["ts"] - res["ts"][0]
    pos   = res["pos"];  vel   = res["vel"]
    euler = res["euler"]
    roll  = np.degrees(euler[:,0])
    pitch = np.degrees(euler[:,1])
    yaw   = np.degrees(euler[:,2])
    cls   = res["classes"]
    raw   = res["raw"]
    rg    = res["raster_gyro"]
    ro    = res["raster_out"]
    mp    = res["mem_pot"]
    vmag  = np.linalg.norm(vel, axis=1)
    amag  = np.linalg.norm(raw[:,4:7], axis=1)
    gm    = np.linalg.norm(raw[:,1:4], axis=1)

    plt.rcParams.update({
        "figure.facecolor":"#070910","axes.facecolor":"#0c0f18",
        "axes.edgecolor":"#1e2233","axes.labelcolor":"#a8b4cc",
        "xtick.color":"#485068","ytick.color":"#485068",
        "text.color":"#a8b4cc","grid.color":"#141828",
        "grid.linewidth":0.45,"lines.linewidth":1.2,
        "font.family":"monospace","font.size":7.5,
    })

    C = dict(x="#00d8ff", y="#39ff14", z="#ff8c42",
             mag="#ffd700", s0="#80ff80", s1="#ffaa00", s2="#ff4466",
             sp="#b070ff", mem="#ff88cc", lc="#ff50a0")

    CLASS_COLOR = [C["s0"], C["s1"], C["s2"]]
    CLASS_LABEL = ["STATIC","SLOW","FAST"]

    fig = plt.figure(figsize=(26, 20))
    fig.suptitle(
        "Spiking Neural Network (SNN) IMU SLAM Pipeline  —  "
        "LIF Neurons · Rate Coding · STDP · WTA Classifier",
        fontsize=15, fontweight="bold", color="#dde2f4", y=0.985)
    gs = gridspec.GridSpec(4, 4, figure=fig, hspace=0.55, wspace=0.38)

    def mkax(r, c, title, proj=None):
        a = fig.add_subplot(gs[r,c], projection=proj) if proj \
            else fig.add_subplot(gs[r,c])
        a.set_title(title, color="#4e6080", fontsize=7.5, pad=3)
        if not proj: a.grid(True, alpha=0.3)
        return a

    # ── Row 0: raw signals ───────────────────────────────────────────────────
