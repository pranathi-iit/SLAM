# 5.  SNN Velocity & Position Integrator
# ══════════════════════════════════════════════════════════════════════════════

class SNNIntegrator:
    """
    Spike-weighted numerical integrator.

    Instead of integrating raw float acceleration, we:
      1. Encode world-frame accel as spike train
      2. Weight each spike by the decoded acceleration value
      3. Accumulate into velocity, then position

    The SNN motion-class gating replaces ZUPT:
      STATIC → velocity reset (no integration)
      SLOW   → half-weight integration (conservative)
      FAST   → full integration

    This makes drift correction a *learned, neural* decision rather than
    a hard threshold.
    """
    def __init__(self):
        self.acc_enc = RateEncoder(n_channels=3, n_pop=6,
                                   val_min=-15.0, val_max=15.0)
        self.vel = np.zeros(3)
        self.pos = np.zeros(3)

    def step(self, a_world: np.ndarray, motion_class: int, dt: float):
        spikes  = self.acc_enc.encode(a_world, dt)
        a_dec   = self.acc_enc.decode(spikes)     # spike-decoded acceleration

        # Motion-class gating
        if motion_class == 0:         # STATIC
            self.vel[:] = 0.0
            a_eff = np.zeros(3)
        elif motion_class == 1:       # SLOW — conservative integration
            a_eff = a_dec * 0.4
        else:                         # FAST — full integration
            a_eff = a_dec

        self.vel += a_eff * dt
        self.pos += self.vel * dt
        return self.pos.copy(), self.vel.copy(), spikes


