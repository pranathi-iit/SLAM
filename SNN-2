# 2.  Rate Encoder  (real value → spike train)
# ══════════════════════════════════════════════════════════════════════════════

class RateEncoder:
    """
    Population rate coding:
    Each scalar input channel is encoded by N_POP neurons.
    Neuron k fires at rate proportional to how close the input is to
    its preferred value (Gaussian tuning curve).

    This gives better precision than single-neuron rate coding and is
    biologically plausible (place cells, grid cells in hippocampus).

    For signed inputs we use two populations: positive and negative.
    """
    def __init__(self, n_channels: int, n_pop: int = 6,
                 val_min: float = -20.0, val_max: float = 20.0,
                 max_rate: float = 200.0):
        self.nc      = n_channels
        self.npop    = n_pop
        self.max_r   = max_rate
        self.centers = np.linspace(val_min, val_max, n_pop)
        self.sigma   = (val_max - val_min) / (n_pop - 1) * 0.8

        # One LIF layer per channel × population
        self.neurons = LIFNeuron(n_channels * n_pop,
                                 tau=0.005, v_thresh=0.9,
                                 t_ref=0.001, R=1.2)
        self._phase = np.random.uniform(0, 1, n_channels * n_pop)

    def encode(self, values: np.ndarray, dt: float) -> np.ndarray:
        """
        values : (n_channels,)
        Returns spikes : (n_channels × n_pop,)
        """
        # Gaussian tuning: firing rate for each population neuron
        rates = np.zeros(self.nc * self.npop)
        for c, v in enumerate(values):
            for p, ctr in enumerate(self.centers):
                idx = c * self.npop + p
                rates[idx] = self.max_r * np.exp(
                    -0.5 * ((v - ctr) / self.sigma)**2)

        # Convert rate → current (Poisson-like deterministic)
        I = rates * dt + 0.05 * np.random.randn(len(rates))
        return self.neurons.step(I, dt)

    def decode(self, spikes: np.ndarray) -> np.ndarray:
        """
        Population vector decoding:
        ̂x = Σ(spike_k × center_k) / Σ(spike_k)   per channel
        """
        decoded = np.zeros(self.nc)
        for c in range(self.nc):
            seg   = spikes[c*self.npop:(c+1)*self.npop]
            total = seg.sum()
            if total > 0:
                decoded[c] = np.dot(seg, self.centers) / total
            else:
                decoded[c] = 0.0
        return decoded


