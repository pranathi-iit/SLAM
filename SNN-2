# ══════════════════════════════════════════════════════════════════════════════
# 1.  LIF Neuron  (Leaky Integrate-and-Fire)
# ══════════════════════════════════════════════════════════════════════════════

class LIFNeuron:
    """
    Membrane potential equation:
        τ · dV/dt = −V + R·I(t)

    Discretised (Euler):
        V[t+1] = V[t] · (1 − dt/τ) + I(t) · dt/τ

    Fires (spike=1) when V ≥ V_thresh, then resets to V_reset.
    Stays silent during refractory period t_ref after a spike.
    """
    def __init__(self, n_neurons: int,
                 tau: float = 0.02,        # membrane time constant (s)
                 v_thresh: float = 1.0,    # firing threshold
                 v_reset: float = 0.0,     # post-spike reset potential
                 v_rest: float = 0.0,      # resting potential
                 t_ref: float = 0.002,     # refractory period (s)
                 R: float = 1.0):          # membrane resistance
        self.n  = n_neurons
        self.tau = tau; self.thresh = v_thresh
        self.reset = v_reset; self.rest = v_rest
        self.t_ref = t_ref; self.R = R

        self.V   = np.full(n_neurons, v_rest, dtype=float)
        self.ref = np.zeros(n_neurons, dtype=float)   # refractory countdown

    def step(self, I: np.ndarray, dt: float) -> np.ndarray:
        """
        I : (n_neurons,) input current vector
        Returns: spike vector (0/1)
        """
        active = self.ref <= 0                        # not refractory

        # Euler integration only for active neurons
        leak = (self.rest - self.V) / self.tau
        self.V += dt * (leak + self.R * I / self.tau) * active

        # Fire
        spikes = (self.V >= self.thresh) & active
        self.V[spikes]   = self.reset
        self.ref[spikes] = self.t_ref

        # Decay refractory
        self.ref = np.maximum(0.0, self.ref - dt)
        return spikes.astype(float)

    def reset_state(self):
        self.V[:]  = self.rest
        self.ref[:] = 0.0


