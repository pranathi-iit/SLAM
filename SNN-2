# Synthetic IMU Generator
# ══════════════════════════════════════════════════════════════════════════════

def generate_synthetic_imu(duration=30.0, hz=200, seed=0):
    np.random.seed(seed)
    dt = 1.0/hz; N = int(duration*hz)
    ts = np.arange(N)*dt

    roll0=np.radians(65.0); pitch0=np.radians(5.0)
    g_body = np.array([
        -np.sin(pitch0),
         np.sin(roll0)*np.cos(pitch0),
         np.cos(roll0)*np.cos(pitch0)]) * GRAVITY

    gx=np.zeros(N); gy=np.zeros(N); gz=np.zeros(N)
    ax=np.full(N,g_body[0])
    ay=np.full(N,g_body[1])
    az=np.full(N,g_body[2])

    # Walk phases
    s=lambda t: int(t*hz)
    ax[s(2.5):s(2.5)+40] += 0.6   # forward push
    ax[s(7.5):s(7.5)+40] -= 0.6   # brake
    gz[s(8):s(12)] += 0.25         # turn left
    ax[s(12.5):s(12.5)+40] += 0.5
    ax[s(22):s(22)+40] -= 0.5

    noise_g=0.003; noise_a=0.04
    gx += np.random.randn(N)*noise_g + 0.0012
    gy += np.random.randn(N)*noise_g - 0.0010
    gz += np.random.randn(N)*noise_g + 0.0011
    ax += np.random.randn(N)*noise_a
    ay += np.random.randn(N)*noise_a
    az += np.random.randn(N)*noise_a

    return np.column_stack([ts,gx,gy,gz,ax,ay,az])


