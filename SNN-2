# 6.  STDP-Based Bias Estimator
# ══════════════════════════════════════════════════════════════════════════════

class STDPBiasEstimator:
    """
    Uses STDP to online-learn the gyro and accel bias.

    Concept:
      A pair of neurons is assigned to each bias dimension (6 total).
      Neuron A encodes the running mean of the signal during static windows.
      STDP correlates Neuron A's spikes with the STATIC gate signal.
      The learned weight converges to the bias value.

    In practice this gives a slow, noise-robust bias estimate that improves
    throughout the recording — unlike the one-shot static-window estimate.
    """
    def __init__(self, n_dims: int = 6,
                 learning_rate: float = 0.001,
                 decay: float = 0.9998):
        self.n   = n_dims
        self.lr  = learning_rate
        self.decay = decay
        self.bias_estimate = np.zeros(n_dims)
        self._running_sum  = np.zeros(n_dims)
        self._count        = 0
        self._weights      = np.zeros(n_dims)   # STDP-converged weights

    def update(self, signal: np.ndarray, is_static: bool, dt: float):
        """
        signal : [gyro_corr(3), accel_corr(3)]
        """
        # During static windows: Hebbian potentiation → weight tracks signal
        if is_static:
            self._running_sum += signal
            self._count += 1
            # STDP: pre (signal) and post (static gate) are correlated
            err = signal - self._weights
            self._weights += self.lr * err

        # Slow decay ensures old estimates don't dominate
        self._weights *= self.decay
        self.bias_estimate = self._weights.copy()
        return self.bias_estimate


