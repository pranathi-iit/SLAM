# 3.  SNN Orientation Network (gyro spikes → roll/pitch/yaw)
# ══════════════════════════════════════════════════════════════════════════════

class SNNOrientationNetwork:
    """
    Two-layer SNN:
      Layer 1  (encoder)  : 3 gyro channels × 6 pop neurons = 18 neurons
      Layer 2  (integrator): 3 output neurons (one per axis)

    The integrator neurons accumulate weighted spike input from the encoder.
    Output = running weighted integral of gyro spikes → orientation estimate.

    STDP adjusts encoder→integrator weights online to reduce drift.
    """
    def __init__(self):
        # Encoder: 3 gyro channels
        self.gyro_enc = RateEncoder(n_channels=3, n_pop=8,
                                    val_min=-20.0, val_max=20.0)
        # Accel encoder for tilt correction
        self.acc_enc  = RateEncoder(n_channels=3, n_pop=6,
                                    val_min=-15.0, val_max=15.0)

        # Integrator neurons (one per orientation axis)
        self.integrator = LIFNeuron(3, tau=0.05, v_thresh=0.8,
                                    v_reset=0.0, t_ref=0.002)

        # Synaptic weights: gyro_enc (24) → integrator (3)
        n_pre = 3 * 8
        self.W_gyro = np.random.uniform(0.01, 0.05, (3, n_pre))

        # Accel → integrator correction weights (18 → 3)
        n_acc = 3 * 6
        self.W_acc  = np.random.uniform(0.005, 0.02, (3, n_acc))

        # STDP parameters
        self.A_plus  = 0.005    # potentiation amplitude
        self.A_minus = 0.003    # depression amplitude
        self.tau_stdp = 0.02    # STDP time window (s)

        # State
        self.orientation = np.zeros(3)        # [roll, pitch, yaw] rad
        self._last_pre_t  = np.full(3*8, -1.0)
        self._last_post_t = np.full(3,   -1.0)
        self._t = 0.0

    def step(self, gyro_raw: np.ndarray, accel_raw: np.ndarray,
             gyro_bias: np.ndarray, dt: float) -> np.ndarray:
        self._t += dt
        gyro_corr = gyro_raw - gyro_bias

        # ── Encode ────────────────────────────────────────────────────────
        gyro_spikes = self.gyro_enc.encode(gyro_corr, dt)   # (24,)
        acc_spikes  = self.acc_enc.encode(accel_raw,  dt)   # (18,)

        # ── Synaptic current to integrator neurons ─────────────────────────
        I_gyro = self.W_gyro @ gyro_spikes               # (3,)
        I_acc  = self.W_acc  @ acc_spikes * 0.3          # tilt correction
        I_total = I_gyro + I_acc

        # ── Integrator fire ────────────────────────────────────────────────
        post_spikes = self.integrator.step(I_total, dt)   # (3,)

        # ── STDP weight update ─────────────────────────────────────────────
        self._stdp_update(gyro_spikes, post_spikes, dt)

        # ── Orientation integration ────────────────────────────────────────
        # Decode gyro rate from spikes, integrate to angle
        omega_decoded = self.gyro_enc.decode(gyro_spikes)  # rad/s estimate
        self.orientation += omega_decoded * dt

        # Accel tilt correction for roll & pitch (complementary filter style)
        acc_dec = self.acc_enc.decode(acc_spikes)
        a_norm = np.linalg.norm(acc_dec)
        if a_norm > 0.5:
            roll_acc  = np.arctan2(acc_dec[1], acc_dec[2])
            pitch_acc = np.arctan2(-acc_dec[0],
                                   np.sqrt(acc_dec[1]**2 + acc_dec[2]**2))
            alpha = 0.02   # complementary filter coefficient (trust accel 2%)
            self.orientation[0] = (1-alpha)*self.orientation[0] + alpha*roll_acc
            self.orientation[1] = (1-alpha)*self.orientation[1] + alpha*pitch_acc

        # Wrap to [-π, π]
        self.orientation = (self.orientation + np.pi) % (2*np.pi) - np.pi
        return self.orientation.copy(), gyro_spikes, acc_spikes, post_spikes

    def _stdp_update(self, pre: np.ndarray, post: np.ndarray, dt: float):
        """
        STDP rule:
          pre  fires before post → potentiate (strengthen weight)
          post fires before pre  → depress    (weaken weight)
        Uses exponential decay window.
        """
        t = self._t
        for j in range(3):         # post neurons
            if post[j] > 0:        # post fired
                # Potentiate: all pre that fired recently
                dt_pre = t - self._last_pre_t
                dW = self.A_plus * np.exp(-dt_pre / self.tau_stdp)
                self.W_gyro[j] += dW
                self._last_post_t[j] = t
            # Depression: post fired recently, pre fires now
            for i in np.where(pre > 0)[0]:
                if self._last_post_t[j] > 0:
                    dt_post = t - self._last_post_t[j]
                    dW = -self.A_minus * np.exp(-dt_post / self.tau_stdp)
                    self.W_gyro[j, i] += dW

        for i in np.where(pre > 0)[0]:
            self._last_pre_t[i] = t

        # Clip weights to [0, 0.5] to prevent explosion
        self.W_gyro = np.clip(self.W_gyro, 0.0, 0.5)


