# 7.  Full SNN SLAM Pipeline
# ══════════════════════════════════════════════════════════════════════════════

class SNNSLAMPipeline:
    def __init__(self, n_static: int = 200):
        self.n_static = n_static
        self.orient_net  = SNNOrientationNetwork()
        self.classifier  = SNNMotionClassifier()
        self.integrator  = SNNIntegrator()
        self.bias_est    = STDPBiasEstimator(n_dims=6)

    def _static_init(self, data):
        static = data[:self.n_static]
        gyro_bias  = static[:, 1:4].mean(axis=0)
        accel_mean = static[:, 4:7].mean(axis=0)
        g_mag = np.linalg.norm(accel_mean)
        roll  = np.arctan2(accel_mean[1], accel_mean[2])
        pitch = np.arctan2(-accel_mean[0],
                           np.sqrt(accel_mean[1]**2 + accel_mean[2]**2))
        accel_bias = accel_mean - g_mag * np.array([
            -np.sin(pitch),
             np.cos(pitch)*np.sin(roll),
             np.cos(pitch)*np.cos(roll)])

        self.orient_net.orientation = np.array([roll, pitch, 0.0])
        return gyro_bias, accel_bias

    def run(self, data: np.ndarray):
        N  = len(data)
        ts = data[:, 0]

        gyro_bias, accel_bias = self._static_init(data)
        g_world = np.array([0., 0., GRAVITY])
        print(f"[INIT]  Gyro bias  : {gyro_bias}")
        print(f"[INIT]  Accel bias : {accel_bias}")

        # Output buffers
        pos_h    = np.zeros((N, 3))
        vel_h    = np.zeros((N, 3))
        euler_h  = np.zeros((N, 3))
        class_h  = np.zeros(N, dtype=int)
        gbias_h  = np.zeros((N, 3))
        abias_h  = np.zeros((N, 3))
        # Spike rasters (store 18 orientation-layer spikes for visualisation)
        raster_gyro = np.zeros((N, 24))
        raster_out  = np.zeros((N, 3))
        mem_pot     = np.zeros((N, 3))

        for i in range(N):
            dt = float(ts[i]-ts[i-1]) if i > 0 else DT_SIM
            dt = np.clip(dt, 1e-4, 0.05)

            gyro_raw  = data[i, 1:4]
            accel_raw = data[i, 4:7]
            gyro_corr = gyro_raw  - gyro_bias
            accel_corr= accel_raw - accel_bias

            # ── SNN orientation network ───────────────────────────────────
            euler, g_spikes, a_spikes, o_spikes = \
                self.orient_net.step(gyro_raw, accel_raw, gyro_bias, dt)
            euler_h[i] = euler

            # ── SNN motion classifier ─────────────────────────────────────
            motion_class, cls_spikes = \
                self.classifier.step(gyro_corr, accel_raw, dt)
            class_h[i] = motion_class

            # ── STDP bias estimator ───────────────────────────────────────
            is_static = (motion_class == 0)
            signal6   = np.concatenate([gyro_corr, accel_corr])
            bias6     = self.bias_est.update(signal6, is_static, dt)
            gbias_h[i] = bias6[:3];  abias_h[i] = bias6[3:]

            # ── Rotation matrix from SNN-estimated euler ──────────────────
            r, p, y = euler
            cr,sr = np.cos(r),np.sin(r)
            cp,sp = np.cos(p),np.sin(p)
            cy,sy = np.cos(y),np.sin(y)
            Rx = np.array([[1,0,0],[0,cr,-sr],[0,sr,cr]])
            Ry = np.array([[cp,0,sp],[0,1,0],[-sp,0,cp]])
            Rz = np.array([[cy,-sy,0],[sy,cy,0],[0,0,1]])
            R  = Rz @ Ry @ Rx

            # ── World-frame linear acceleration ───────────────────────────
            a_world = R @ accel_raw - g_world

            # ── SNN integrator ────────────────────────────────────────────
            pos, vel, int_spikes = \
                self.integrator.step(a_world, motion_class, dt)
            pos_h[i] = pos;  vel_h[i] = vel

            # ── Save spike rasters ────────────────────────────────────────
            raster_gyro[i] = g_spikes
            raster_out[i]  = o_spikes
            mem_pot[i]     = self.orient_net.integrator.V.copy()

        n_static = int((class_h == 0).sum())
        print(f"[DONE]  {N} samples | {ts[-1]-ts[0]:.2f}s")
        print(f"[SNN]   STATIC : {n_static}  ({100*n_static/N:.1f}%)")
        print(f"[SNN]   SLOW   : {int((class_h==1).sum())}  "
              f"({100*(class_h==1).mean():.1f}%)")
        print(f"[SNN]   FAST   : {int((class_h==2).sum())}  "
              f"({100*(class_h==2).mean():.1f}%)")
        print(f"[TRAJ]  Final pos (m): {pos_h[-1]}")

        return dict(
            ts=ts, pos=pos_h, vel=vel_h, euler=euler_h,
            classes=class_h, gbias=gbias_h, abias=abias_h,
            raster_gyro=raster_gyro, raster_out=raster_out,
            mem_pot=mem_pot, raw=data
        )


