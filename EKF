    def mkax(r, c, title, proj=None):
        a = fig.add_subplot(gs[r,c], projection=proj) if proj else fig.add_subplot(gs[r,c])
        a.set_title(title, color="#5a7090", fontsize=7.5, pad=3)
        if not proj: a.grid(True, alpha=0.35)
        return a

    # ── Row 0: raw signals ───────────────────────────────────────────────────
