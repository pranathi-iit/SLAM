    a03.set_ylabel("σ (m)")

    # ── Row 1: orientation ────────────────────────────────────────────────────
    a10 = mkax(1,0,"Orientation — Roll (°)")
    a10.plot(ts,roll,C["x"]); a10.set_xlabel("t(s)")

    a11 = mkax(1,1,"Orientation — Pitch (°)")
    a11.plot(ts,pitch,C["y"]); a10.set_xlabel("t(s)")

    a12 = mkax(1,2,"Orientation — Yaw (°)")
    a12.plot(ts,yaw,C["z"]); a12.set_xlabel("t(s)")

    a13 = mkax(1,3,"EKF: velocity std-dev  (m/s)")
    a13.plot(ts,sv[:,0],C["x"],label="σ_vx")
    a13.plot(ts,sv[:,1],C["y"],label="σ_vy")
    a13.plot(ts,sv[:,2],C["z"],label="σ_vz")
