def plot_ekf(res, save_path=None):
    ts    = res["ts"] - res["ts"][0]
    pos   = res["pos"]; vel = res["vel"]
    euler = res["euler"]
    roll  = np.degrees(euler[:,0])
    pitch = np.degrees(euler[:,1])
    yaw   = np.degrees(euler[:,2])
    gbias = res["gbias"]; abias = res["abias"]
    sp    = res["std_pos"]; sv = res["std_vel"]
    zupt  = res["zupt"]; clos = res["closure"]
    raw   = res["raw"]; kfs = res["keyframes"]
    vmag  = np.linalg.norm(vel, axis=1)
    amag  = np.linalg.norm(raw[:,4:7], axis=1)

    plt.rcParams.update({
        "figure.facecolor":"#080a0f","axes.facecolor":"#0e1118",
        "axes.edgecolor":"#202535","axes.labelcolor":"#b0b8cc",
        "xtick.color":"#505870","ytick.color":"#505870",
        "text.color":"#b0b8cc","grid.color":"#161c28",
        "grid.linewidth":0.5,"lines.linewidth":1.3,
        "font.family":"monospace","font.size":7.5,
    })

    C = dict(x="#00d8ff",y="#39ff14",z="#ff8c42",
             mag="#ffd700",zu="#80ff80",lc="#ff50a0",
             sp="#5b9dff",err="#ff4060",cov="#9966ff")

    fig = plt.figure(figsize=(26,18))
    fig.suptitle(
        "EKF Tightly-Coupled IMU SLAM  —  15-State Navigation Filter",
        fontsize=16, fontweight="bold", color="#dde2f4", y=0.985)
