    a21.plot(ts,gbias[:,0],C["x"],label="bgx")
    a21.plot(ts,gbias[:,1],C["y"],label="bgy")
    a21.plot(ts,gbias[:,2],C["z"],label="bgz")
    a21.legend(fontsize=6); a21.set_xlabel("t(s)")
    a21.set_ylabel("bias (rad/s)")

    a22 = mkax(2,2,"EKF accel bias estimate  (m/s²)")
    a22.plot(ts,abias[:,0],C["x"],label="bax")
    a22.plot(ts,abias[:,1],C["y"],label="bay")
    a22.plot(ts,abias[:,2],C["z"],label="baz")
    a22.legend(fontsize=6); a22.set_xlabel("t(s)")
    a22.set_ylabel("bias (m/s²)")

    a23 = mkax(2,3,"ZUPT innovation  |Δv|  (m/s)")
    inn = res["zupt_inn"].copy()
    inn[inn==0] = np.nan
    a23.plot(ts,inn,".",color=C["zu"],ms=2,alpha=.6)
    a23.set_xlabel("t(s)"); a23.set_ylabel("m/s")

    # ── Row 3: trajectories ───────────────────────────────────────────────────
    a30 = mkax(3,0,"2D Trajectory  X–Y")
    sc = a30.scatter(pos[:,0],pos[:,1],c=ts,cmap="plasma",s=2,alpha=.8)
    if kfs:
        kfpos = np.array([p for _,p in kfs])
        a30.scatter(kfpos[:,0],kfpos[:,1],c="white",s=18,
                    zorder=5,label="Keyframes",marker="^",alpha=.7)
    for i in np.where(clos)[0]:
        a30.scatter(pos[i,0],pos[i,1],c=C["lc"],s=30,zorder=6,marker="x")
    a30.plot(*pos[0,:2],"o",color=C["y"],ms=8,label="Start",zorder=7)
    a30.plot(*pos[-1,:2],"*",color=C["z"],ms=12,label="End",zorder=7)
    plt.colorbar(sc,ax=a30,label="t(s)",pad=0.02)
    a30.set_aspect("equal","datalim"); a30.legend(fontsize=6)
    a30.set_xlabel("X(m)"); a30.set_ylabel("Y(m)")

    a31 = mkax(3,1,"2D Trajectory  X–Z")
    sc2 = a31.scatter(pos[:,0],pos[:,2],c=ts,cmap="viridis",s=2,alpha=.8)
    plt.colorbar(sc2,ax=a31,label="t(s)",pad=0.02)
    a31.set_aspect("equal","datalim")
    a31.set_xlabel("X(m)"); a31.set_ylabel("Z(m)")

    a32 = mkax(3,2,"3D Trajectory",proj="3d")
    a32.set_facecolor("#0e1118")
    n=len(pos); step=max(1,n//300)
    for i in range(0,n-step,step):
        c=plt.cm.plasma(i/n)
        a32.plot(pos[i:i+step+1,0],pos[i:i+step+1,1],pos[i:i+step+1,2],
                 color=c,lw=1.1,alpha=.85)
    if kfs:
        a32.scatter(kfpos[:,0],kfpos[:,1],kfpos[:,2],c="white",s=20,
                    marker="^",zorder=5,label="KF",alpha=.8)
    a32.scatter(*pos[0],color=C["y"],s=50,zorder=6)
    a32.scatter(*pos[-1],color=C["z"],s=80,marker="*",zorder=6)
    a32.set_title("3D Trajectory",color="#5a7090",fontsize=7.5,pad=4)
    a32.set_xlabel("X",fontsize=7); a32.set_ylabel("Y",fontsize=7)
    a32.set_zlabel("Z",fontsize=7)
    a32.tick_params(colors="#505870",labelsize=6)

    # Stats panel
    a33 = mkax(3,3,"Pipeline report")
    a33.axis("off")
    report = (
        f"  ╔══ EKF SLAM Report ══════════════╗\n"
        f"  ║ Duration        : {ts[-1]:.2f} s\n"
        f"  ║ Samples         : {len(ts)}\n"
        f"  ║ Sample rate     : {1/np.mean(np.diff(ts)):.1f} Hz\n"
        f"  ╠═══════════════════════════════╣\n"
        f"  ║ State dim       : 15\n"
        f"  ║ ZUPT frames     : {zupt.sum()} ({100*zupt.mean():.1f}%)\n"
        f"  ║ Keyframes       : {len(kfs)}\n"
        f"  ║ Loop closures   : {int(clos.sum())}\n"
        f"  ╠═══════════════════════════════╣\n"
        f"  ║ Peak |ω|        : {gm.max():.2f} rad/s\n"
        f"  ║ Peak |a|        : {amag.max():.2f} m/s²\n"
        f"  ║ Peak speed      : {vmag.max():.3f} m/s\n"
        f"  ╠═══════════════════════════════╣\n"
        f"  ║ Final pos X     : {pos[-1,0]:.3f} m\n"
        f"  ║ Final pos Y     : {pos[-1,1]:.3f} m\n"
        f"  ║ Final pos Z     : {pos[-1,2]:.3f} m\n"
        f"  ║ Final σ pos     : {sp[-1,0]:.3f} m\n"
        f"  ╚═══════════════════════════════╝\n"
    )
    a33.text(0.02, 0.97, report, transform=a33.transAxes,
             fontsize=7.5, verticalalignment="top",
             fontfamily="monospace", color="#8aaBb8",
             bbox=dict(facecolor="#141828",edgecolor="#2a3050",
                       boxstyle="round,pad=0.5"))

    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches="tight",
                    facecolor=fig.get_facecolor())
        print(f"[PLOT]  Saved → {save_path}")
    return fig


