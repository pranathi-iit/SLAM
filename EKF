# Entry point
# ═══════════════════════════════════════════════════════════════════════════

def main():
    imu_path = "imu.txt"
    # Create a dummy imu.txt file if it doesn't exist
    if not Path(imu_path).exists():
        print(f"[INFO] Creating a dummy '{imu_path}' file.")
        dummy_data = np.zeros((1000, 7))
        dummy_data[:, 0] = np.arange(1000) * 0.01  # time (100 Hz)
        dummy_data[:, 4] = 9.81  # accel_z (gravity)
        np.savetxt(imu_path, dummy_data, delimiter=' ')

    out_png  = "imu_ekf_result.png" # Fixed: always use default for Colab
    out_csv  = "imu_ekf_trajectory.csv" # Fixed: always use default for Colab

    print("="*60)
    print("  EKF Tightly-Coupled IMU SLAM  —  15-State Filter")
    print("="*60)

    data = np.loadtxt(imu_path, comments="#")
    print(f"[LOAD]  {data.shape[0]} samples from '{imu_path}'")

    res = run_ekf_slam(data,
                       zupt_thresh=0.04,
                       zupt_win=15,
                       n_static=200,
                       enable_loop_closure=True)

    # CSV
    t_rel = res["ts"] - res["ts"][0]
    out = np.column_stack([
        t_rel, res["pos"], res["vel"],
        np.degrees(res["euler"]),
        res["gbias"], res["abias"],
        res["std_pos"], res["std_vel"],
        res["zupt"].astype(int),
        res["closure"].astype(int),
    ])
    hdr = ("time_s,x,y,z,vx,vy,vz,"
           "roll_deg,pitch_deg,yaw_deg,"
           "gbx,gby,gbz,abx,aby,abz,"
           "sx,sy,sz,svx,svy,svz,"
           "zupt,loop_closure")
    np.savetxt(out_csv, out, delimiter=",", header=hdr, comments="")
    print(f"[CSV]   Saved → {out_csv}")

    plot_ekf(res, save_path=out_png)

if __name__ == "__main__":
    main()
