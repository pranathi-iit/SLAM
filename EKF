    a00.plot(ts,raw[:,1],C["x"],label="ωx",alpha=.8)
    a00.plot(ts,raw[:,2],C["y"],label="ωy",alpha=.8)
    a00.plot(ts,raw[:,3],C["z"],label="ωz",alpha=.8)
    a00.legend(fontsize=6); a00.set_xlabel("t(s)")

    a01 = mkax(0,1,"Raw accelerometer  (m/s²)")
    a01.plot(ts,raw[:,4],C["x"],label="ax",alpha=.8)
    a01.plot(ts,raw[:,5],C["y"],label="ay",alpha=.8)
    a01.plot(ts,raw[:,6],C["z"],label="az",alpha=.8)
    a01.legend(fontsize=6); a01.set_xlabel("t(s)")

    a02 = mkax(0,2,"|Accel| magnitude + |Gyro|  (m/s²)")
    a02.plot(ts,amag,C["mag"],lw=1.2,label="|accel|")
    a02.axhline(GRAVITY,color=C["err"],ls="--",lw=0.8,label="g")
    gm = np.linalg.norm(raw[:,1:4],axis=1)
    ax2b = a02.twinx()
    ax2b.plot(ts,gm,C["sp"],lw=0.9,alpha=.6,label="|ω|")
    ax2b.set_ylabel("|ω| (rad/s)", color=C["sp"], fontsize=7)
    ax2b.tick_params(colors=C["sp"])
    a02.legend(fontsize=6,loc="upper left"); a02.set_xlabel("t(s)")

    a03 = mkax(0,3,"EKF: pos std-deviation  (m)")
    a03.plot(ts,sp[:,0],C["x"],label="σ_X")
    a03.plot(ts,sp[:,1],C["y"],label="σ_Y")
    a03.plot(ts,sp[:,2],C["z"],label="σ_Z")
